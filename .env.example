# Cole aqui a "Connection string" do seu banco Postgres gratuito (Supabase, Neon, Railway etc.)
DATABASE_URL="postgresql://usuario:senha@host:5432/banco?sslmode=require"

# Senha única de acesso ao sistema
APP_SENHA="escolha-uma-senha-forte"

# Segredo aleatório para assinar a sessão de login. Gere um com: openssl rand -hex 32
AUTH_SECRET="troque-por-uma-string-aleatoria-longa"

# Nome exibido no app (menu lateral, tela de login, mensagens de WhatsApp/e-mail)
NEXT_PUBLIC_APP_NAME="Transporte da Mamãe"
